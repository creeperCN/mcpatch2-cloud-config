# ================================================================
#  Mcpatch 云控管理端 — 环境配置模板
#  复制此文件为 .env 并修改配置
# ================================================================

# 数据库路径（SQLite）
DATABASE_URL=file:./db/custom.db

# NextAuth 密钥（JWT 签名，必须为随机字符串！）
# 生成方式: openssl rand -base64 32
NEXTAUTH_SECRET=

# 服务端口
PORT=3000

# 运行环境（生产环境请保持 production）
NODE_ENV=production
